---
const base = import.meta.env.BASE_URL;

const cards = [
  {
    num: '01',
    title: 'Count Valid Subarrays',
    desc: 'Prefix sum + hashmap, sliding window, DP, and monotonic stack',
    href: `${base}/cards/01_count_valid_subarrays`,
    accent: '#3b82f6',
  },
  {
    num: '02',
    title: 'Integer Overflow',
    desc: 'Digit reversal, binary search mid, modular arithmetic, big integers',
    href: `${base}/cards/02_integer_overflow`,
    accent: '#f59e0b',
  },
  {
    num: '03',
    title: 'Backtracking',
    desc: 'Subsets, permutations, grid search, constraint satisfaction, string partitioning',
    href: `${base}/cards/03_backtracking`,
    accent: '#8b5cf6',
  },
  {
    num: '04',
    title: 'Graph Algorithms',
    desc: 'BFS, DFS, topological sort, union-find, shortest path',
    href: `${base}/cards/04_graph`,
    accent: '#10b981',
  },
  {
    num: '05',
    title: 'Linked List & Binary Tree',
    desc: 'Pointer manipulation, tree traversal, recursion patterns',
    href: `${base}/cards/05_linkedlist_binarytree`,
    accent: '#ef4444',
  },
  {
    num: '06',
    title: 'Company Interview Patterns',
    desc: 'Topic frequencies and difficulty distributions at Google, Meta, Apple, TikTok',
    href: `${base}/cards/06_company_interview_patterns`,
    accent: '#f97316',
  },
  {
    num: '—',
    title: 'Subarray Sum = K Guide',
    desc: 'Deep dive into LeetCode 560 and its variants with annotated solutions',
    href: `${base}/cards/subarray_sum_k_leetcode_guide_with_links`,
    accent: '#06b6d4',
  },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AlgoCards — Algorithm Pattern Reference</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #ffffff;
      --border: #1e2230;
      --text: #1e2230;
      --muted: #6b7280;
      --hover-surface: rgb(255, 255, 255)
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Mono', monospace;
      min-height: 100vh;
      padding: 3rem 1.5rem;
    }

    header {
      max-width: 900px;
      margin: 0 auto 3rem;
    }

    .label {
      font-family: 'DM Mono', monospace;
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 0.75rem;
    }

    h1 {
      font-family: 'Syne', sans-serif;
      font-size: clamp(1.75rem, 5vw, 2.75rem);
      font-weight: 700;
      color: var(--text);
      line-height: 1.15;
      margin-bottom: 0.75rem;
    }

    .subtitle {
      font-size: 0.85rem;
      color: var(--muted);
      line-height: 1.6;
    }

    .grid-wrapper {
      position: relative;
      max-width: 900px;
      margin: 0 auto;
      overflow: visible;
    }

    .square {
      position: absolute;
      background: rgba(195, 198, 246, 0.2);
      border-radius: 4px;
      pointer-events: none;
      z-index: 0;
    }

    .grid {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 1rem;
    }

    .card {
      display: block;
      text-decoration: none;
      background: rgba(255, 255, 255, 0.2);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.5rem;
      transition: background 0.15s, border-color 0.15s, transform 0.15s;
      position: relative;
      overflow: hidden;
    }

    .card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 2px;
      background: var(--accent);
      opacity: 0;
      transition: opacity 0.15s;
    }

    .card:hover {
      background: var(--hover-surface);
      border-color: #2a3040;
      transform: translateY(-2px);
    }

    .card:hover::before {
      opacity: 1;
    }

    .card-num {
      font-family: 'DM Mono', monospace;
      font-size: 0.7rem;
      font-weight: 500;
      color: var(--accent);
      letter-spacing: 0.08em;
      margin-bottom: 0.6rem;
    }

    .card-title {
      font-family: 'Syne', sans-serif;
      font-size: 1rem;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 0.5rem;
      line-height: 1.3;
    }

    .card-desc {
      font-size: 0.75rem;
      color: var(--muted);
      line-height: 1.6;
    }

    footer {
      max-width: 900px;
      margin: 3rem auto 0;
      padding-top: 1.5rem;
      border-top: 1px solid var(--border);
      font-size: 0.7rem;
      color: var(--muted);
      letter-spacing: 0.04em;
    }
  </style>
</head>
<body>
  <header>
    <p class="label">Algorithm Reference</p>
    <h1 id="box">AlgoCards</h1>
    <p class="subtitle">Pattern-first reference cards for coding interviews.</p>
  </header>

  <div class="grid-wrapper">
    <div class="square" style="width:120px;height:120px;top:-30px;left:-50px;"></div>
    <div class="square" style="width:80px;height:80px;top:60px;right:-20px;"></div>
    <div class="square" style="width:160px;height:160px;bottom:-40px;left:30%;"></div>
    <div class="square" style="width:60px;height:60px;bottom:20px;right:60px;"></div>
    <div class="square" style="width:100px;height:100px;top:40%;left:-30px;"></div>
    <main class="grid">
      {cards.map(card => (
        <a class="card" href={card.href} style={`--accent: ${card.accent}`}>
          <p class="card-num">Pattern {card.num}</p>
          <p class="card-title">{card.title}</p>
          <p class="card-desc">{card.desc}</p>
        </a>
      ))}
    </main>
  </div>

  <footer>
    <p>AlgoCards — LeetCode pattern reference</p>
  </footer>
</body>
</html>

<script>
import { animate, stagger, splitText, createDraggable, waapi, utils } from 'animejs';

const { chars } = splitText('h1', { words: false, chars: true });

animate(chars, {
  y: [
    { to: '-2.75rem', ease: 'outExpo', duration: 600 },
    { to: 0, ease: 'outBounce', duration: 800, delay: 100 }
  ],
  rotate: {
    from: '-1turn',
    delay: 0
  },
  delay: stagger(50),
  ease: 'inOutCirc',
  loopDelay: 1000,
  loop: true
});

const $squares = utils.$('.square');

const animateSquares = () => {
  waapi.animate($squares, {
    x: () => utils.random(-50, -10) + 'rem',
    y: () => utils.random(-50, -10) + 'rem',
    rotateX: () => utils.random(-90, 90),
    rotateY: () => utils.random(-90, 90),
    onComplete: () => animateSquares()
  });
}

animateSquares();
</script>